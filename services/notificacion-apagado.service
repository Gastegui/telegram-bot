[Unit]
Description=Notificacion por telegram cuando se apaga el sistema
DefaultDependencies=no
Before=shutdown.target reboot.target halt.target
Requires=network-online.target
After=network-online.target

[Service]
Type=oneshot
ExecStart=/bin/true
ExecStop=/home/pi/bot/mensaje-apagado.sh
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
